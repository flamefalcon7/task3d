# Copy to `backend/.env` (gitignored). The dev script (`pnpm dev`) reads it
# via Node's --env-file flag — see backend/package.json scripts.

# REQUIRED — must be at least 32 bytes (hex strings work). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-32-or-more-bytes

# OPTIONAL — Claude Haiku for the LLM router. Without it, the backend falls
# back to HardcodedRouter (slider mode only — Forge prompt mode will fail).
# ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — Tripo prompt-to-mesh. Both must be set together; either alone
# hard-fails on first /generate call with shape=tripo.
# TRIPO_ENABLED=true
# TRIPO_API_KEY=...
