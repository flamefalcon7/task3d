# Anthropic API key powers the AnthropicRouter (Claude Haiku tool-use).
# Absent or shorter than 16 chars → backend falls back to HardcodedRouter
# (slider-mode only; prompt-mode disabled).
# ANTHROPIC_API_KEY=

# Gate for the Tripo (image/text-to-3D) generator. Demo posture (P6) keeps
# this false on submission; AnthropicRouter throws TripoDisabledError when
# the LLM routes to tripo and this is not "true".
TRIPO_ENABLED=false

# HS256 secret for session JWTs (U4). MUST be at least 32 bytes — server
# refuses to start otherwise. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=
