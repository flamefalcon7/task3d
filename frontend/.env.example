# Copy this to `.env.local` (gitignored) and fill in the values.
# `.env.local` is read by Vite at dev + build time per https://vitejs.dev/guide/env-and-mode.

# Sui Move package id for model3d::model3d. Captured from
# `sui client publish` after deploying contracts/model3d to testnet.
# Set to `0x0` to keep PTB builders + indexer hooks degenerate (no real reads).
VITE_MODEL3D_PACKAGE_ID=0x0

# OPTIONAL — Enoki + Google for the zkLogin wallet adapter. Without both,
# the Slush wallet adapter is still registered (no functional loss for
# anyone signing in with a browser-extension wallet). Set both together;
# either alone is treated as "not configured".
# VITE_ENOKI_API_KEY=
# VITE_GOOGLE_CLIENT_ID=
