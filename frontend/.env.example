# Copy this to `.env.local` (gitignored) and fill in the values.
# `.env.local` is read by Vite at dev + build time per https://vitejs.dev/guide/env-and-mode.

# Sui Move package id for model3d::model3d. Captured from
# `sui client publish` after deploying contracts/model3d to testnet.
# Set to `0x0` to keep PTB builders + indexer hooks degenerate (no real reads).
VITE_MODEL3D_PACKAGE_ID=0x0

# OPTIONAL — Walrus aggregator base URL for blob reads (audit W-3). Defaults to
# the testnet aggregator when unset. Set this when deploying to mainnet (the
# mainnet aggregator) or to front reads through the CDN worker
# (https://cdn.tusk3d.space). MUST match the network the blobs were uploaded to,
# or every preview/GLB read 404s after a network switch.
# VITE_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# OPTIONAL — L2 "Riff Copilot" conversational prompt authoring (D-081). Default OFF.
# Set to "true" ONLY when the backend has GOOGLE_GENERATIVE_AI_API_KEY configured;
# otherwise the "Chat with Copilot" toggle on /create would appear but break on
# first use. Non-secret feature flag (the Gemini key stays backend-only, never VITE_).
# VITE_COPILOT_ENABLED=true

# OPTIONAL — Enoki + Google for the zkLogin wallet adapter. Without both,
# the Slush wallet adapter is still registered (no functional loss for
# anyone signing in with a browser-extension wallet). Set both together;
# either alone is treated as "not configured".
# VITE_ENOKI_API_KEY=
# VITE_GOOGLE_CLIENT_ID=

# OPTIONAL — DEV ONLY — Test wallet adapter (plan-016).
# Bypasses Slush by signing locally with an Ed25519 keypair. Use for demo
# recording and agent-browser automation when Slush is unavailable or
# crashes the renderer (see docs/brainstorms/2026-05-27-test-wallet-adapter-
# requirements.md).
#
# SAFETY:
#   - NEVER set these in a production build. The frontend refuses to load
#     the test-wallet module when import.meta.env.PROD is true.
#   - VITE_TEST_WALLET_KEY must be a TESTNET key. Mainnet keys would be
#     signing live mainnet transactions on /launch.
#   - Bech32 format = `suiprivkey1...` (what `sui keytool export` produces).
#   - .env.local is gitignored. Do NOT commit the key.
#
# When unset, the wrapper hooks (frontend/src/wallet/*) tree-shake the
# entire test-wallet subtree out of the production bundle (verified by
# AE4 grep at plan-016 §U6).
# VITE_TEST_WALLET=1
# VITE_TEST_WALLET_KEY=suiprivkey1...
